---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { otherLocale } from '../i18n/utils';
import { languageNames, type Locale } from '../i18n/config';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const other = otherLocale(locale);
const otherUrl = getRelativeLocaleUrl(other, '');
---
<div class="inline-flex overflow-hidden rounded-full border border-[--color-line] text-xs">
  <span class="bg-brand px-2.5 py-1 text-white">{languageNames[locale]}</span>
  <a href={otherUrl} class="px-2.5 py-1 text-[--color-muted] hover:text-[--color-ink]">
    {languageNames[other]}
  </a>
</div>
