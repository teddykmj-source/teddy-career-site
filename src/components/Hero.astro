---
import BackgroundMesh from './BackgroundMesh.astro';
import StatStrip from './StatStrip.astro';
import Icon from './Icon.astro';
import { contact } from '../data/contact';
import type { SiteContent } from '../data/types';
interface Props { content: SiteContent; }
const { content } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<header class="relative overflow-hidden px-7 pb-9 pt-12 text-center md:px-9">
  <BackgroundMesh />
  <div class="relative z-10">
    <div class="mx-auto mb-5 h-20 w-20 rounded-full bg-white bg-cover"
         style={`background-image:url('${base}profile.jpg'); background-size:150%; background-position:50% 18%; box-shadow:0 0 0 3px rgba(255,255,255,0.18);`}
         role="img" aria-label="Teddy · Minjae Kim"></div>
    <p class="mb-3 text-xs tracking-[0.2em] text-[#BFD6F0]">{content.eyebrow}</p>
    <h1 class="mb-3.5 text-[28px] font-medium leading-tight tracking-tight text-white">
      {content.headline.map((line, i) => (<>{line}{i < content.headline.length - 1 && <br />}</>))}
    </h1>
    <p class="mx-auto mb-6 max-w-md text-sm leading-relaxed text-[#D6E4F5]">{content.tagline}</p>
    <div class="mb-8 flex justify-center gap-2.5">
      <a href={`mailto:${contact.email}`} data-glass class="glass-btn glass-btn--primary px-4 py-2 text-[13px]">
        <span class="glass-btn__inner"><Icon name="mail" class="w-4 h-4" />{content.ctaContact}</span>
      </a>
      <a href={contact.linkedin} target="_blank" rel="noopener" data-glass class="glass-btn px-4 py-2 text-[13px] text-white">
        <span class="glass-btn__inner"><Icon name="linkedin" class="w-4 h-4" />LinkedIn</span>
      </a>
    </div>
    <StatStrip stats={content.stats} />
  </div>
</header>

<style>
  .glass-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.12);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    backdrop-filter: blur(14px) saturate(160%);
    box-shadow: 0 4px 18px rgba(8, 20, 40, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s ease, background 0.35s ease;
  }
  .glass-btn__inner {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .glass-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(120px circle at var(--mx, 50%) var(--my, 0%), rgba(255, 255, 255, 0.4), transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .glass-btn::after {
    content: "";
    position: absolute;
    top: 0;
    left: -130%;
    z-index: 1;
    width: 55%;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(100deg, transparent, rgba(255, 255, 255, 0.5), transparent);
    transform: skewX(-18deg);
  }
  .glass-btn:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.18);
    box-shadow: 0 10px 28px rgba(8, 20, 40, 0.36), inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .glass-btn:hover::before { opacity: 1; }
  .glass-btn:hover::after { animation: glass_sheen 0.7s ease; }
  .glass-btn:active { transform: translateY(0) scale(0.98); }
  .glass-btn--primary {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.6);
    color: var(--color-brand);
  }
  .glass-btn--primary:hover { background: rgba(255, 255, 255, 0.95); }
  @keyframes glass_sheen {
    from { left: -130%; }
    to { left: 170%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .glass-btn { transition: none; }
    .glass-btn:hover { transform: none; }
    .glass-btn:hover::after { animation: none; }
    .glass-btn::before { display: none; }
  }
</style>

<script>
  // Hero 글래스 버튼: 커서 위치를 따라 빛 반사(--mx/--my) 갱신
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    document.querySelectorAll('[data-glass]').forEach((el) => {
      el.addEventListener('pointermove', (e) => {
        const r = el.getBoundingClientRect();
        el.style.setProperty('--mx', `${e.clientX - r.left}px`);
        el.style.setProperty('--my', `${e.clientY - r.top}px`);
      });
    });
  }
</script>
