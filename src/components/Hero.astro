---
import BackgroundMesh from './BackgroundMesh.astro';
import StatStrip from './StatStrip.astro';
import Icon from './Icon.astro';
import { contact } from '../data/contact';
import type { SiteContent } from '../data/types';
interface Props { content: SiteContent; }
const { content } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<header class="relative overflow-hidden px-7 pb-9 pt-12 text-center md:px-9">
  <BackgroundMesh />
  <div class="relative z-10">
    <div class="mx-auto mb-5 h-20 w-20 rounded-full bg-white bg-cover"
         style={`background-image:url('${base}profile.jpg'); background-position:50% 12%; box-shadow:0 0 0 3px rgba(255,255,255,0.18);`}
         role="img" aria-label="Teddy · Minjae Kim"></div>
    <p class="mb-3 text-xs tracking-[0.2em] text-[#BFD6F0]">{content.eyebrow}</p>
    <h1 class="mb-3.5 text-[28px] font-medium leading-tight tracking-tight text-white">
      {content.headline.map((line, i) => (<>{line}{i < content.headline.length - 1 && <br />}</>))}
    </h1>
    <p class="mx-auto mb-6 max-w-md text-sm leading-relaxed text-[#D6E4F5]">{content.tagline}</p>
    <div class="mb-8 flex justify-center gap-2.5">
      <a href={`mailto:${contact.email}`} class="inline-flex items-center gap-1.5 rounded-lg bg-white px-4 py-2 text-[13px] text-brand">
        <Icon name="mail" class="w-4 h-4" />{content.ctaContact}
      </a>
      <a href={contact.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-lg border border-white/40 px-4 py-2 text-[13px] text-white hover:bg-white/10">
        <Icon name="linkedin" class="w-4 h-4" />LinkedIn
      </a>
    </div>
    <StatStrip stats={content.stats} />
  </div>
</header>
