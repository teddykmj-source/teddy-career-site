---
import type { Stat } from '../data/types';
interface Props { stats: Stat[]; }
const { stats } = Astro.props;
---
<div class="mx-auto grid max-w-lg grid-cols-2 gap-3 sm:grid-cols-4">
  {stats.map((s) => (
    <div class="rounded-lg bg-white/10 px-2 py-3.5 text-center">
      <div class="text-[22px] font-medium text-white">{s.value}</div>
      <div class="mt-0.5 text-xs text-[#BFD6F0]">{s.label}</div>
    </div>
  ))}
</div>
