---
import SectionLayout from './SectionLayout.astro';
import type { SiteContent } from '../data/types';
interface Props { content: SiteContent; }
const { content } = Astro.props;
---
<SectionLayout id="activities" title={content.activitiesTitle}>
  <ul class="flex flex-col gap-2.5">
    {content.activities.map((a) => (
      <li class="flex gap-2.5 text-sm leading-relaxed text-[--color-muted]">
        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-brand"></span>
        <span>{a}</span>
      </li>
    ))}
  </ul>
</SectionLayout>
